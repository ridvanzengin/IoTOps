# Copy to .env.prod and fill in all values before first deploy.

# -- Database -----------------------------------------------------------
# Must match the password set for the iotops DB user in SERVER_SETUP.md.
# The full TIMESCALE_URI is assembled in docker-compose.prod.yml using
# this value.
IOTOPS_DB_PASSWORD=change-me-strong-password

# -- Demo mode ------------------------------------------------------------
# true for the public demo deployment -- blocks every mutating
# Collector/Automater endpoint server-side (see backend/app/config.py's
# `demo` flag and block_in_demo_mode() in backend/app/dependencies.py).
# AI endpoints are deliberately NOT blocked by this (see app/ai/api.py) --
# they run for real against the free-tier Gemini backend below, degrading
# to a generic "This is a demo -- AI features are temporarily limited"
# message (not a raw provider error) if that free tier is rate-limited,
# unreachable, or its key is simply missing.
DEMO=true

# Lets examples/demo/seed.py's own one-time provisioning requests through
# the DEMO gate above without weakening it for anyone else -- generate
# with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# Passed to both backend (checks it) and demo-showcase (sends it); never
# proxied by nginx, internal-network-only.
DEMO_SEED_TOKEN=change-me-random-token

# -- CORS -------------------------------------------------------------
# Moot for same-origin browser traffic once nginx routes both frontend and
# /api under one domain, but the default (localhost:5173) would be wrong
# in prod -- set it correctly anyway.
FRONTEND_ORIGIN=https://iotops.online

# -- AI -------------------------------------------------------------------
# AI_PROVIDER defaults to "gemini" (see backend/app/config.py) -- a real
# key from https://aistudio.google.com/apikey (free tier) is REQUIRED for
# this deployment, or every AI request 502s with a demo-mode message
# instead of actually working. No ANTHROPIC_API_KEY needed unless you
# override AI_PROVIDER=anthropic below.
GEMINI_API_KEY=change-me-gemini-api-key
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=change-me-anthropic-api-key
