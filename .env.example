MONGO_URI=mongodb://mongo:27017/iotops
TIMESCALE_URI=postgresql://iotops:iotops@timescaledb:5432/iotops
MQTT_HOST=mosquitto
MQTT_PORT=1883
REDIS_URI=redis://redis:6379/0
FRONTEND_ORIGIN=http://localhost:5173

# Absolute host path to this repo's runtime/ directory. Required so the
# backend (talking to the host Docker daemon via a mounted docker.sock)
# can bind-mount generated Telegraf configs into sibling containers it
# creates. Example: /Users/you/personal/IoTOps/runtime
HOST_RUNTIME_DIR=

# Which backend powers every AI feature (Co-pilot chat and AI-assisted SQL
# generation alike): "anthropic" or "gemini". Only the matching key/model
# pair below needs a real value.
AI_PROVIDER=gemini

# Your own Anthropic API key. Get one at
# https://console.anthropic.com/settings/keys. ANTHROPIC_MODEL defaults to
# claude-haiku-4-5 (cheapest current Claude model) if left unset.
ANTHROPIC_API_KEY=YourAnthropicAPIKeyHere
ANTHROPIC_MODEL=claude-haiku-4-5

# Free-tier alternative when the Anthropic budget runs out -- set
# AI_PROVIDER=gemini above to use this instead. Get a free key at
# https://aistudio.google.com/apikey. GEMINI_MODEL defaults to
# gemini-2.0-flash if left unset.
GEMINI_API_KEY=YourGeminiAPIKeyHere
GEMINI_MODEL=gemini-2.0-flash