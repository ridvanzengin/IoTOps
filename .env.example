MONGO_URI=mongodb://mongo:27017/iotops
TIMESCALE_URI=postgresql://iotops:iotops@timescaledb:5432/iotops
MQTT_HOST=mosquitto
MQTT_PORT=1883
REDIS_URI=redis://redis:6379/0
FRONTEND_ORIGIN=http://localhost:5173

# Absolute host path to this repo's runtime/ directory. Required so the
# backend (talking to the host Docker daemon via a mounted docker.sock)
# can bind-mount generated Telegraf configs into sibling containers it
# creates. Example: /Users/you/personal/IoTOps/runtime
HOST_RUNTIME_DIR=
